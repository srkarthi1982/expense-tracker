---
import { AvButton, AvCard, AvContainer, AvEmptyState, AvTimeline } from "@ansiversa/components";
import { db, eq, and, Accounts, Categories, Transactions } from "astro:db";
import { buildExpenseTrackerSummary } from "../dashboard/summary.schema";
import AppShell from "../layouts/AppShell.astro";
import type { AccountDTO, CategoryDTO, TransactionDTO } from "../modules/expense-tracker/types";

export const prerender = false;

const title = "Expense Tracker – Ansiversa";
const description = "Track income and expenses with a clean daily overview.";
const publicFeatureCards = [
  {
    title: "Category-first tracking",
    description: "Log income and expenses with clean category context so review stays useful later.",
  },
  {
    title: "Clear balance visibility",
    description: "Keep income, expenses, and account movement understandable without spreadsheet clutter.",
  },
  {
    title: "Fast daily logging",
    description: "Capture real-life money activity quickly enough to stay consistent day after day.",
  },
  {
    title: "Account-aware entries",
    description: "Track where money sits and moves so your records stay grounded in actual accounts.",
  },
];
const publicPillars = [
  {
    date: "Pillar 01",
    title: "Simple daily money logging",
    body: "Add entries in a lightweight flow that fits normal routines instead of turning into admin work.",
  },
  {
    date: "Pillar 02",
    title: "Clear category organization",
    body: "Review spending by purpose so recurring patterns are easier to spot and correct.",
  },
  {
    date: "Pillar 03",
    title: "Better income vs expense visibility",
    body: "Keep the relationship between what comes in and what goes out visible at a glance.",
  },
  {
    date: "Pillar 04",
    title: "Account-based structure",
    body: "Track entries against real accounts so balances and activity make practical sense.",
  },
  {
    date: "Pillar 05",
    title: "Clean recent activity review",
    body: "See the latest movement in one place without mixing product messaging with fake dashboard states.",
  },
  {
    date: "Pillar 06",
    title: "Lightweight workflow for real life",
    body: "Designed for consistency, clarity, and calm daily tracking rather than feature overload.",
  },
];
const devBypassUserId =
  import.meta.env.DEV && String(import.meta.env.DEV_AUTH_BYPASS ?? "").toLowerCase() === "true"
    ? String(import.meta.env.DEV_AUTH_BYPASS_USER_ID ?? "").trim()
    : "";
const userId = Astro.locals.user?.id ?? devBypassUserId;
const hasUser = userId.length > 0;

const [accountsResult, categoriesResult, transactionsResult, summary] = await Promise.all(
  hasUser
    ? [
        db.select().from(Accounts).where(and(eq(Accounts.userId, userId), eq(Accounts.isArchived, false))),
        db.select().from(Categories).where(eq(Categories.userId, userId)),
        db.select().from(Transactions).where(eq(Transactions.userId, userId)),
        buildExpenseTrackerSummary(userId),
      ]
    : [
        Promise.resolve([]),
        Promise.resolve([]),
        Promise.resolve([]),
        buildExpenseTrackerSummary(""),
      ],
);

const accounts = (accountsResult ?? []) as AccountDTO[];
const categories = (categoriesResult ?? []) as CategoryDTO[];
const transactions = ((transactionsResult ?? []) as TransactionDTO[])
  .sort((a, b) => {
    const aTime = new Date(a.transactionDate ?? a.createdAt ?? 0).getTime();
    const bTime = new Date(b.transactionDate ?? b.createdAt ?? 0).getTime();
    return bTime - aTime;
  });

const recentTransactions = transactions.slice(0, 5);

const categoryById = new Map(categories.map((category) => [category.id, category.name]));

const expenseByCategory = transactions
  .filter((transaction) => transaction.type === "expense" && transaction.categoryId)
  .reduce((acc, transaction) => {
    const categoryId = transaction.categoryId as string;
    const amount = Number(transaction.amount ?? 0);
    acc.set(categoryId, (acc.get(categoryId) ?? 0) + amount);
    return acc;
  }, new Map<string, number>());

let topExpenseCategory = "No expense data yet";
let topExpenseAmount = 0;

for (const [categoryId, amount] of expenseByCategory.entries()) {
  if (amount > topExpenseAmount) {
    topExpenseAmount = amount;
    topExpenseCategory = categoryById.get(categoryId) ?? "Uncategorized";
  }
}

const latestTransaction = recentTransactions[0];

const formatCurrency = (value: number) => {
  if (summary.currencyMode === "mixed") {
    return "Unavailable";
  }

  if (!summary.currencyCode) {
    return value.toFixed(2);
  }

  return new Intl.NumberFormat("en-US", {
    style: "currency",
    currency: summary.currencyCode,
    minimumFractionDigits: 2,
  }).format(value);
};

const formatTransactionAmount = (transaction: TransactionDTO) => {
  const transactionCurrency = String(transaction.currency ?? "").trim().toUpperCase();
  const accountCurrency = String(
    accounts.find((account) => account.id === transaction.accountId)?.currency ?? "",
  ).trim().toUpperCase();
  const currency = transactionCurrency || accountCurrency || summary.currencyCode || "";

  if (!currency) {
    return Number(transaction.amount ?? 0).toFixed(2);
  }

  return new Intl.NumberFormat("en-US", {
    style: "currency",
    currency,
    minimumFractionDigits: 2,
  }).format(Number(transaction.amount ?? 0));
};

const currencyStatusMessage =
  summary.currencyMode === "mixed"
    ? "Mixed currencies detected. Expense Tracker V1 only supports trusted totals when one currency is used across the app."
    : summary.currencyCode
      ? `V1 app currency: ${summary.currencyCode}`
      : "Expense Tracker V1 works as a single-currency app. Set one currency on your accounts or transactions to lock it in.";
---

<AppShell title={title} description={description}>
  {hasUser ? (
    <>
      <section class="av-section">
        <AvContainer>
          <div class="home-hero-grid">
            <div class="av-auth-stack-md">
              <p class="av-kicker">Lifestyle & Personal · Ansiversa Mini App</p>
              <h1 class="av-gradient-text">Expense Tracker</h1>
              <p class="av-text-soft">
                A calm place to track spending and income daily without spreadsheet clutter.
              </p>
              <ul class="home-bullets">
                <li>See income, expenses, and current balance in seconds.</li>
                <li>Organize every entry with clean account and category context.</li>
                <li>Keep your money picture useful for daily decisions.</li>
              </ul>
              <p class="av-text-soft">{currencyStatusMessage}</p>
              <div class="av-row-wrap">
                <AvButton href="/app/expense-tracker">View transactions</AvButton>
                <AvButton href="/help" variant="ghost">Help</AvButton>
              </div>
            </div>

            <AvCard className="av-auth-stack-md" variant="soft">
              <p class="av-kicker">Today at a glance</p>
              <div class="home-panel-grid">
                <div>
                  <p class="av-text-soft">Total income</p>
                  <p class="home-number">{formatCurrency(summary.totalIncome)}</p>
                </div>
                <div>
                  <p class="av-text-soft">Total expense</p>
                  <p class="home-number">{formatCurrency(summary.totalExpense)}</p>
                </div>
                <div>
                  <p class="av-text-soft">Current balance</p>
                  <p class="home-number">{formatCurrency(summary.currentBalance)}</p>
                </div>
                <div>
                  <p class="av-text-soft">Transactions</p>
                  <p class="home-number">{summary.recentTransactionCount}</p>
                </div>
              </div>
              <div class="home-callouts av-auth-stack-xs">
                <p class="av-text-soft">Top expense category: <strong>{topExpenseCategory}</strong></p>
                <p class="av-text-soft">
                  Latest activity:
                  <strong>
                    {latestTransaction
                      ? `${latestTransaction.type} · ${formatTransactionAmount(latestTransaction)}`
                      : "No transactions yet"}
                  </strong>
                </p>
              </div>
            </AvCard>
          </div>
        </AvContainer>
      </section>

      <section class="av-section">
        <AvContainer>
          <div class="home-summary-strip">
            <AvCard variant="soft">
              <p class="av-text-soft">Total income</p>
              <h2 class="av-section-title">{formatCurrency(summary.totalIncome)}</h2>
            </AvCard>
            <AvCard variant="soft">
              <p class="av-text-soft">Total expense</p>
              <h2 class="av-section-title">{formatCurrency(summary.totalExpense)}</h2>
            </AvCard>
            <AvCard variant="soft">
              <p class="av-text-soft">Current balance</p>
              <h2 class="av-section-title">{formatCurrency(summary.currentBalance)}</h2>
            </AvCard>
            <AvCard variant="soft">
              <p class="av-text-soft">Transactions</p>
              <h2 class="av-section-title">{summary.recentTransactionCount}</h2>
            </AvCard>
          </div>
        </AvContainer>
      </section>

      <section class="av-section">
        <AvContainer size="narrow">
          <div class="av-section-header">
            <h2 class="av-section-title">What makes Expense Tracker different</h2>
          </div>
          <div class="home-pillars">
            <AvCard variant="soft">
              <h3 class="av-card-heading">Category-first tracking</h3>
              <p class="av-text-soft">Log every expense or income entry in a way that stays easy to review later.</p>
            </AvCard>
            <AvCard variant="soft">
              <h3 class="av-card-heading">Clear balance visibility</h3>
              <p class="av-text-soft">Know where you stand with starting balances plus transaction effects shown as one current balance.</p>
            </AvCard>
            <AvCard variant="soft">
              <h3 class="av-card-heading">Fast daily logging</h3>
              <p class="av-text-soft">Add entries quickly so tracking stays lightweight and realistic for daily life.</p>
            </AvCard>
          </div>
        </AvContainer>
      </section>

      <section class="av-section">
        <AvContainer>
          <div class="av-row-between app-row-top">
            <div>
              <h2 class="av-section-title">Recent transactions</h2>
              <p class="av-text-soft">Your latest money activity in one compact list.</p>
            </div>
            <AvButton href="/app/expense-tracker" variant="ghost">Open full tracker</AvButton>
          </div>

          {recentTransactions.length === 0 ? (
            <AvCard variant="soft">
              <AvEmptyState
                title="No transactions yet"
                description="Add your first transaction to start building your summary."
              />
              <div class="home-empty-cta">
                <AvButton href="/app/expense-tracker">Create first transaction</AvButton>
              </div>
            </AvCard>
          ) : (
            <div class="home-recent-list av-auth-stack-sm">
              {recentTransactions.map((transaction) => (
                <AvCard variant="soft" className="av-row-between app-row-top">
                  <div>
                    <p class="av-card-heading">{formatTransactionAmount(transaction)}</p>
                    <p class="av-text-soft">
                      {categoryById.get(transaction.categoryId ?? "") ?? "Uncategorized"} · {(String(transaction.transactionDate || "")).slice(0, 10)}
                    </p>
                  </div>
                  <span class="av-badge av-badge-soft">{transaction.type}</span>
                </AvCard>
              ))}
            </div>
          )}
        </AvContainer>
      </section>
    </>
  ) : (
    <>
      <section class="av-hero">
        <AvContainer size="default">
          <div class="av-hero__grid">
            <div class="av-hero__content av-auth-stack-md">
              <div class="av-kicker">
                <span>Lifestyle & Personal · Ansiversa Mini App</span>
              </div>
              <h1 class="av-section-title">Expense Tracker</h1>
              <p class="av-section-lead">
                Track income and expenses without spreadsheet clutter, and keep daily money decisions grounded in one clear workflow.
              </p>
              <ul class="av-list">
                <li>Log income and expense entries with account and category context</li>
                <li>Review balances and activity without switching between scattered notes</li>
                <li>Use one currency across the app so totals remain trusted in V1</li>
                <li>Stay consistent with a lightweight daily tracking routine</li>
              </ul>
              <div class="av-row-wrap">
                <AvButton href="/app/expense-tracker">Start tracking</AvButton>
                <AvButton href="/help" variant="ghost">Help</AvButton>
              </div>
              <p class="av-text-soft">Simple logging. Clean review. Better money visibility.</p>
            </div>

            <AvCard variant="soft" className="av-auth-stack-sm">
              <p class="av-kicker">Expense flow</p>
              <h2 class="av-card-heading">Log → Organize → Review</h2>
              <ol class="av-list">
                <li>1. Add income and expense entries</li>
                <li>2. Organize each record by category and account</li>
                <li>3. Review current balance and recent activity in one place</li>
              </ol>
              <div class="av-row-between">
                <p class="av-text-soft">Focus: daily clarity</p>
                <p class="av-text-soft">Workflow: account-aware</p>
              </div>
            </AvCard>
          </div>
        </AvContainer>
      </section>

      <section class="av-section">
        <AvContainer size="default">
          <div class="av-section-header">
            <h2 class="av-section-title">At a glance</h2>
            <p class="av-section-lead">Expense Tracker is built to make regular money logging feel calm, structured, and sustainable.</p>
          </div>
          <div class="home-summary-strip">
            <AvCard variant="soft">
              <h3 class="av-card-heading">Income and expense entries</h3>
              <p class="av-text-soft">Capture the money moving in and out without turning the process into a spreadsheet chore.</p>
            </AvCard>
            <AvCard variant="soft">
              <h3 class="av-card-heading">Categories and accounts</h3>
              <p class="av-text-soft">Keep each transaction connected to where it belongs so later review still makes sense.</p>
            </AvCard>
            <AvCard variant="soft">
              <h3 class="av-card-heading">Balances and activity</h3>
              <p class="av-text-soft">See the bigger picture and the latest movement together instead of piecing it together manually.</p>
            </AvCard>
          </div>
        </AvContainer>
      </section>

      <section class="av-section">
        <AvContainer size="default">
          <div class="av-section-header">
            <h2 class="av-section-title">Feature highlights</h2>
            <p class="av-section-lead">The essentials for clear personal expense tracking, without fake dashboard placeholders.</p>
          </div>
          <div class="home-feature-grid">
            {publicFeatureCards.map((feature) => (
              <AvCard variant="soft" className="av-auth-stack-sm av-card--fullheight">
                <h3 class="av-card-heading">{feature.title}</h3>
                <p class="av-text-soft">{feature.description}</p>
              </AvCard>
            ))}
          </div>
        </AvContainer>
      </section>

      <section class="av-section">
        <AvContainer size="default">
          <div class="av-section-header">
            <h2 class="av-section-title">Why Expense Tracker</h2>
            <p class="av-section-lead">A clean system for people who want better visibility without adding friction to daily life.</p>
          </div>
          <AvTimeline items={publicPillars} />
        </AvContainer>
      </section>

      <section class="av-section">
        <AvContainer size="default">
          <div class="av-section-header">
            <div class="av-kicker"><span>How it works</span></div>
            <h2 class="av-section-title">Set up → Log → Review</h2>
            <p class="av-section-lead">Three simple steps from getting started to staying consistent.</p>
          </div>
          <ol class="av-steps">
            <li class="av-step">
              <span class="av-step-number">1</span>
              <div class="av-step-body">
                <h3 class="av-card-heading">Set up your context</h3>
                <p>Add the accounts and categories that match how you actually track money.</p>
              </div>
            </li>
            <li class="av-step">
              <span class="av-step-number">2</span>
              <div class="av-step-body">
                <h3 class="av-card-heading">Log income and expenses</h3>
                <p>Record daily entries quickly so the tracker reflects real activity instead of best intentions.</p>
              </div>
            </li>
            <li class="av-step">
              <span class="av-step-number">3</span>
              <div class="av-step-body">
                <h3 class="av-card-heading">Review balances and activity</h3>
                <p>Use the tracker to understand where money is moving and what needs attention next.</p>
              </div>
            </li>
          </ol>
        </AvContainer>
      </section>

      <section class="av-section">
        <AvContainer size="default">
          <AvCard variant="soft" className="av-row-between av-card--fullheight">
            <div class="av-auth-stack-xxs">
              <h2 class="av-section-title">Ready to start tracking your money?</h2>
              <p class="av-text-soft">Sign in to use Expense Tracker and create your first entry.</p>
            </div>
            <AvButton href="/app/expense-tracker">Open Expense Tracker</AvButton>
          </AvCard>
        </AvContainer>
      </section>
    </>
  )}
</AppShell>

<style>
  .home-hero-grid {
    display: grid;
    gap: 1rem;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    align-items: start;
  }

  .home-bullets {
    color: #cbd5e1;
    list-style: disc;
    padding-left: 1.1rem;
    display: grid;
    gap: 0.35rem;
  }

  .home-panel-grid,
  .home-summary-strip,
  .home-pillars {
    display: grid;
    gap: 0.75rem;
    grid-template-columns: repeat(auto-fit, minmax(170px, 1fr));
  }

  .home-feature-grid {
    display: grid;
    gap: 0.75rem;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
  }

  .home-number {
    font-size: 1.15rem;
    font-weight: 600;
  }

  .home-callouts strong {
    color: #f8fafc;
  }

  .app-row-top {
    align-items: flex-start;
    gap: 0.75rem;
  }

  .home-recent-list :global(.av-card) {
    width: 100%;
  }

  .home-empty-cta {
    margin-top: 0.75rem;
  }
</style>
