---
import {
  AvBreadcrumb,
  AvButton,
  AvCard,
  AvContainer,
  AvEmptyState,
  AvTable,
} from "@ansiversa/components";
import { db, eq, Accounts, Transactions } from "astro:db";
import { actions } from "astro:actions";
import BarListChart from "../../components/charts/BarListChart.astro";
import ComparisonStatChart from "../../components/charts/ComparisonStatChart.astro";
import MiniTrendChart from "../../components/charts/MiniTrendChart.astro";
import TransactionDrawer from "../../components/drawers/TransactionDrawer.astro";
import { buildExpenseTrackerSummary } from "../../dashboard/summary.schema";
import AppShell from "../../layouts/AppShell.astro";
import type { AccountDTO, CategoryDTO, TransactionDTO } from "../../modules/expense-tracker/types";

const title = "Expense Tracker – App";
const description = "Track accounts, categories, and transactions.";
const userId = Astro.locals.user?.id ?? "";

const [allAccountsResult, categoriesResult, transactionsResult, summary] = await Promise.all([
  db.select().from(Accounts).where(eq(Accounts.userId, userId)),
  Astro.callAction(actions.listCategories, { includeArchived: true }),
  db.select().from(Transactions).where(eq(Transactions.userId, userId)),
  buildExpenseTrackerSummary(userId),
]);

const accounts = (allAccountsResult ?? []) as AccountDTO[];
const categoryPayload = ((categoriesResult as any)?.data ?? categoriesResult as any);
const categories = (((categoryPayload as any)?.data ?? categoryPayload as any)?.items ?? []) as CategoryDTO[];
const transactions = ((transactionsResult ?? []) as TransactionDTO[])
  .sort((a, b) => {
    const aTime = new Date(a.transactionDate ?? a.createdAt ?? 0).getTime();
    const bTime = new Date(b.transactionDate ?? b.createdAt ?? 0).getTime();
    return bTime - aTime;
  });

---

<AppShell title={title} description={description}>
  <section class="av-faq-public__crumb">
    <AvContainer>
      <AvBreadcrumb
        items={[
          { label: "Home", href: "/" },
          { label: "Expense Tracker" },
        ]}
      />
    </AvContainer>
  </section>

  <section
    class="av-section"
    x-data="{ typeLabel: { expense: 'Expense', income: 'Income', transfer: 'Transfer' }, activeTab: 'overview' }"
  >
    <AvContainer>
      <div
        class="av-auth-stack-lg"
        x-data="$store.expenseTracker"
        x-init={`init(${JSON.stringify({ accounts, categories, transactions })})`}
        @expense-drawer-open.window="if ($event.detail?.key) { $store.appDrawer.open($event.detail.key) }"
        @expense-drawer-close.window="$store.appDrawer.close()"
      >
        <AvCard className="av-auth-stack-md">
          <div class="av-row-between app-row-top">
            <div>
              <p class="av-kicker">Expense Tracker</p>
              <h1 class="av-section-title">Your financial entries</h1>
              <p class="av-text-soft">Track income and expenses with period-aware insights while keeping your CRUD workflow simple.</p>
            </div>
            <AvButton type="button" @click="activeTab = 'transactions'; openCreateTransaction()">Create transaction</AvButton>
          </div>
          <p class="av-text-soft" x-text="currencyStatusMessage"></p>
          <p class="av-text-soft">Archived accounts stay part of historical totals, but remain hidden from normal account-management lists and selectors.</p>
          <p class="av-text-soft">Archived categories stay part of historical reporting, but new transaction selectors only show active categories compatible with the selected transaction type.</p>
          <template x-if="success">
            <p class="av-text-soft" x-text="success"></p>
          </template>
          <template x-if="error">
            <p class="app-form-error" x-text="error"></p>
          </template>
        </AvCard>

        <AvCard variant="soft" className="av-auth-stack-md">
          <div class="av-row-between app-row-top">
            <div>
              <p class="av-kicker">Workspace</p>
              <h2 class="av-card-heading">Focus one area at a time</h2>
              <p class="av-text-soft">Use tabs to switch between overview, accounts, categories, and transactions without the long vertical stack.</p>
            </div>
            <p class="av-text-soft">Synced {summary.updatedAt.slice(0, 10)}</p>
          </div>

          <div class="app-tab-list" role="tablist" aria-label="Expense Tracker sections">
            <button type="button" class="app-tab-button" :class="{ 'app-tab-button--active': activeTab === 'overview' }" :aria-selected="activeTab === 'overview'" @click="activeTab = 'overview'">Overview</button>
            <button type="button" class="app-tab-button" :class="{ 'app-tab-button--active': activeTab === 'accounts' }" :aria-selected="activeTab === 'accounts'" @click="activeTab = 'accounts'">Accounts</button>
            <button type="button" class="app-tab-button" :class="{ 'app-tab-button--active': activeTab === 'categories' }" :aria-selected="activeTab === 'categories'" @click="activeTab = 'categories'">Categories</button>
            <button type="button" class="app-tab-button" :class="{ 'app-tab-button--active': activeTab === 'transactions' }" :aria-selected="activeTab === 'transactions'" @click="activeTab = 'transactions'">Transactions</button>
          </div>

          <div class="app-tab-meta">
            <span class="av-text-soft">Accounts: <span x-text="visibleAccounts.length"></span></span>
            <span class="av-text-soft">Categories: <span x-text="visibleCategories.length"></span></span>
            <span class="av-text-soft">Transactions: <span x-text="transactions.length"></span></span>
          </div>
        </AvCard>

        <div x-show="activeTab === 'overview'" class="av-auth-stack-lg">
          <div class="app-summary-grid">
            <AvCard variant="soft">
              <p class="av-text-soft">Current balance</p>
              <h2 class="av-section-title" x-text="formatMoney(currentBalance)"></h2>
              <p class="av-text-soft">Starting balances + all transaction effects</p>
            </AvCard>
            <AvCard variant="soft">
              <p class="av-text-soft">Income (<span x-text="periodLabel"></span>)</p>
              <h2 class="av-section-title" x-text="formatMoney(filteredSummary.income)"></h2>
            </AvCard>
            <AvCard variant="soft">
              <p class="av-text-soft">Expense (<span x-text="periodLabel"></span>)</p>
              <h2 class="av-section-title" x-text="formatMoney(filteredSummary.expense)"></h2>
            </AvCard>
            <AvCard variant="soft">
              <p class="av-text-soft">Net flow (<span x-text="periodLabel"></span>)</p>
              <h2 class="av-section-title" x-text="formatMoney(filteredSummary.netFlow)"></h2>
              <p class="av-text-soft">Transactions: <span x-text="filteredSummary.count"></span></p>
            </AvCard>
          </div>

          <AvCard variant="soft" className="av-auth-stack-md">
            <div class="av-row-between app-row-top">
              <div>
                <p class="av-kicker">Quick actions</p>
                <h2 class="av-card-heading">Record something now</h2>
              </div>
            </div>

            <div class="app-quick-actions">
              <AvButton type="button" @click="activeTab = 'transactions'; openQuickAdd('expense')">Add expense</AvButton>
              <AvButton type="button" variant="ghost" @click="activeTab = 'transactions'; openQuickAdd('income')">Add income</AvButton>
              <AvButton type="button" variant="ghost" @click="activeTab = 'transactions'; repeatLastTransaction('expense')" :disabled="!lastExpenseTransaction">Repeat last expense</AvButton>
              <AvButton type="button" variant="ghost" @click="activeTab = 'transactions'; repeatLastTransaction('income')" :disabled="!lastIncomeTransaction">Repeat last income</AvButton>
            </div>
          </AvCard>

          <AvCard variant="soft">
            <ComparisonStatChart
              title="Income vs expense"
              subtitle="Period-aware comparison based on current filters"
              leftLabel="Income"
              leftValueExpression="incomeVsExpenseComparison.leftValue"
              rightLabel="Expense"
              rightValueExpression="incomeVsExpenseComparison.rightValue"
              emptyText="No income or expense values available for this period."
            />
          </AvCard>

          <AvCard variant="soft" className="av-auth-stack-md">
            <div class="av-row-between app-row-top">
              <h2 class="av-card-heading">Period filters</h2>
              <p class="av-text-soft">Selected: <span x-text="periodLabel"></span></p>
            </div>

            <div class="app-period-presets">
              <AvButton type="button" variant="ghost" @click="setPeriodPreset('all-time')">All time</AvButton>
              <AvButton type="button" variant="ghost" @click="setPeriodPreset('this-month')">This month</AvButton>
              <AvButton type="button" variant="ghost" @click="setPeriodPreset('last-month')">Last month</AvButton>
              <AvButton type="button" variant="ghost" @click="setPeriodPreset('this-year')">This year</AvButton>
              <AvButton type="button" variant="ghost" @click="setPeriodPreset('last-30-days')">Last 30 days</AvButton>
            </div>

            <div class="app-inline-grid">
              <label class="app-field">
                <span class="app-label">Start date</span>
                <input class="app-input" type="date" x-model="customStartDate" />
              </label>
              <label class="app-field">
                <span class="app-label">End date</span>
                <input class="app-input" type="date" x-model="customEndDate" />
              </label>
            </div>

            <div class="av-row-wrap">
              <AvButton type="button" @click="applyCustomDateRange">Apply custom range</AvButton>
              <AvButton type="button" variant="ghost" @click="clearDateFilters">Reset to all time</AvButton>
            </div>

            <template x-if="dateFilterError">
              <p class="app-form-error" x-text="dateFilterError"></p>
            </template>
          </AvCard>

          <div class="app-insight-grid">
            <AvCard variant="soft" className="av-auth-stack-md">
              <div class="av-row-between app-row-top">
                <h2 class="av-card-heading">Category insights</h2>
                <template x-if="filteredTopExpenseCategory">
                  <p class="av-text-soft">
                    Top: <strong x-text="filteredTopExpenseCategory.categoryName"></strong>
                    · <span x-text="formatMoney(filteredTopExpenseCategory.total)"></span>
                  </p>
                </template>
              </div>
              <BarListChart
                title="Category spending"
                subtitle="Descending totals for expense categories"
                itemsExpression="categoryChartItems"
                emptyText="No categorized expenses in this period."
              />
            </AvCard>

            <AvCard variant="soft" className="av-auth-stack-md">
              <MiniTrendChart
                title="Monthly expense trend"
                subtitle="Recent monthly expense totals in selected period"
                pointsExpression="monthlyTrendItems"
                emptyText="No monthly expense trend yet for the selected period."
              />
              <h2 class="av-card-heading">Largest recent expenses in period</h2>
              <template x-if="filteredLargestRecentExpenses.length === 0">
                <p class="av-text-soft">No recent expenses in this period.</p>
              </template>
              <template x-if="filteredLargestRecentExpenses.length > 0">
                <div class="av-auth-stack-xs">
                  <template x-for="transaction in filteredLargestRecentExpenses" :key="transaction.id">
                    <div class="av-card av-card-soft">
                      <p class="av-card-heading" x-text="formatTransactionAmount(transaction)"></p>
                      <p class="av-text-soft">
                        <span x-text="transaction.description || 'No description'"></span>
                        · <span x-text="(String(transaction.transactionDate || '')).slice(0, 10)"></span>
                      </p>
                    </div>
                  </template>
                </div>
              </template>
            </AvCard>
          </div>

          <AvCard variant="soft" className="av-auth-stack-md">
            <div class="av-auth-stack-xs">
              <p class="av-kicker">Smart insights</p>
              <h2 class="av-card-heading">Quick take: <span x-text="quickInsightTake"></span></h2>
            </div>

            <template x-if="smartInsights.length === 0">
              <p class="av-text-soft">Add more transactions to unlock richer spending insights.</p>
            </template>

            <template x-if="smartInsights.length > 0">
              <div class="av-auth-stack-xs">
                <template x-for="insight in smartInsights" :key="insight.id">
                  <article class="app-smart-insight" :class="`app-smart-insight--${insight.tone}`">
                    <p class="app-smart-insight__tone" x-text="insight.tone"></p>
                    <p x-text="insight.text"></p>
                  </article>
                </template>
              </div>
            </template>
          </AvCard>

          <AvCard variant="soft" className="av-auth-stack-md">
            <div class="av-row-between app-row-top">
              <h2 class="av-card-heading">Recent reusable transactions</h2>
              <p class="av-text-soft">Top <span x-text="recentReusableTransactions.length"></span> quick repeats</p>
            </div>

            <template x-if="recentReusableTransactions.length === 0">
              <AvEmptyState
                title="No reusable transactions yet"
                description="As you add entries, quick repeat actions will appear here."
              />
            </template>

            <template x-if="recentReusableTransactions.length > 0">
              <div class="av-auth-stack-xs">
                <template x-for="transaction in recentReusableTransactions" :key="`reuse-${transaction.id}`">
                  <div class="av-card av-card-soft av-row-between app-row-top">
                    <div>
                      <p class="av-card-heading" x-text="formatTransactionAmount(transaction)"></p>
                      <p class="av-text-soft">
                        <span x-text="transaction.description || 'No description'"></span>
                        · <span x-text="(String(transaction.transactionDate || '')).slice(0, 10)"></span>
                      </p>
                    </div>
                    <AvButton type="button" variant="ghost" @click="activeTab = 'transactions'; reuseTransaction(transaction)">Use again</AvButton>
                  </div>
                </template>
              </div>
            </template>
          </AvCard>
        </div>

        <div x-show="activeTab === 'accounts'" class="av-auth-stack-lg">
          <AvCard variant="soft" className="av-auth-stack-md">
          <div class="av-row-between app-row-top">
            <div>
              <h2 class="av-card-heading">Accounts</h2>
              <p class="av-text-soft"><span x-text="visibleAccounts.length"></span> active</p>
            </div>
            <AvButton type="button" @click="openCreateAccount()" :disabled="loading">Create account</AvButton>
          </div>
          <p class="av-text-soft">Expense Tracker V1 uses a single currency across accounts and totals. Your first saved currency becomes the app currency.</p>

          <template x-if="visibleAccounts.length === 0">
            <AvEmptyState
              title="No accounts yet"
              description="Create your first account to start tracking balances and transactions."
            />
          </template>

          <template x-if="visibleAccounts.length > 0">
            <AvTable stickyHeader dense>
              <thead>
                <tr>
                  <th>Name</th>
                  <th>Type</th>
                  <th>Currency</th>
                  <th>Starting balance</th>
                  <th class="av-table__th-actions">Actions</th>
                </tr>
              </thead>
              <tbody>
                <template x-for="account in visibleAccounts" :key="account.id">
                  <tr>
                    <td class="app-table-cell-strong" x-text="account.name"></td>
                    <td class="app-table-cell-muted" x-text="account.type || 'Type not set'"></td>
                    <td class="app-table-cell-muted" x-text="account.currency || 'Currency not set'"></td>
                    <td class="app-table-cell-nowrap" x-text="formatCurrencyAmount(account.startingBalance || 0, account.currency)"></td>
                    <td class="av-table__td-actions">
                      <div class="av-table__cell-actions">
                        <AvButton type="button" size="sm" variant="ghost" @click="archiveAccount(account.id)" :disabled="loading">Archive</AvButton>
                      </div>
                    </td>
                  </tr>
                </template>
              </tbody>
            </AvTable>
          </template>
        </AvCard>
        </div>

        <div x-show="activeTab === 'categories'" class="av-auth-stack-lg">
          <AvCard variant="soft" className="av-auth-stack-md">
          <div class="av-row-between app-row-top">
            <div>
              <h2 class="av-card-heading">Categories</h2>
              <p class="av-text-soft"><span x-text="visibleCategories.length"></span> active</p>
            </div>
            <AvButton type="button" @click="openCreateCategory()" :disabled="loading">Create category</AvButton>
          </div>

          <template x-if="visibleCategories.length === 0">
            <AvEmptyState
              title="No categories yet"
              description="Create categories so expenses and income can be organized clearly."
            />
          </template>

          <template x-if="visibleCategories.length > 0">
            <AvTable stickyHeader dense>
              <thead>
                <tr>
                  <th>Name</th>
                  <th>Kind</th>
                </tr>
              </thead>
              <tbody>
                <template x-for="category in visibleCategories" :key="category.id">
                  <tr>
                    <td class="app-table-cell-strong" x-text="category.name"></td>
                    <td class="app-table-cell-muted" x-text="typeLabel[category.type] || category.type || 'Unspecified'"></td>
                  </tr>
                </template>
              </tbody>
            </AvTable>
          </template>
        </AvCard>
        </div>

        <div x-show="activeTab === 'transactions'" class="av-auth-stack-lg">
          <AvCard variant="soft" className="av-auth-stack-md">
          <div class="av-row-between app-row-top">
            <h2 class="av-card-heading">Transactions</h2>
            <p class="av-text-soft"><span x-text="filteredTransactions.length"></span> in period · <span x-text="transactions.length"></span> total</p>
          </div>

          <template x-if="transactions.length === 0">
            <AvEmptyState
              title="No transactions yet"
              description="Create your first transaction to start tracking totals."
            />
          </template>

          <template x-if="transactions.length > 0 && filteredTransactions.length === 0">
            <AvEmptyState
              title="No transactions in this period"
              description="Try another preset or reset the range to view more activity."
            >
              <div slot="actions">
                <AvButton type="button" variant="ghost" @click="clearDateFilters">Reset to all time</AvButton>
              </div>
            </AvEmptyState>
          </template>

          <template x-if="filteredTransactions.length > 0">
            <AvTable stickyHeader dense>
              <thead>
                <tr>
                  <th>Date</th>
                  <th>Description</th>
                  <th>Type</th>
                  <th>Amount</th>
                  <th>Quick type</th>
                  <th class="av-table__th-actions">Actions</th>
                </tr>
              </thead>
              <tbody>
                <template x-for="transaction in filteredTransactions" :key="transaction.id">
                  <tr>
                    <td class="app-table-cell-nowrap" x-text="(String(transaction.transactionDate || '')).slice(0, 10)"></td>
                    <td class="app-table-cell-strong" x-text="transaction.description || 'No description'"></td>
                    <td class="app-table-cell-muted" x-text="typeLabel[transaction.type] || transaction.type"></td>
                    <td class="app-table-cell-nowrap" x-text="formatTransactionAmount(transaction)"></td>
                    <td>
                      <template x-if="transaction.type === 'transfer'">
                        <span class="app-table-cell-muted">Edit in form</span>
                      </template>
                      <template x-if="transaction.type !== 'transfer'">
                        <select
                          class="app-input app-input--table"
                          :value="transaction.type"
                          @change="quickUpdateType(transaction.id, $event.target.value)"
                          :disabled="loading"
                        >
                          <option value="expense">Expense</option>
                          <option value="income">Income</option>
                        </select>
                      </template>
                    </td>
                    <td class="av-table__td-actions">
                      <div class="av-table__cell-actions">
                        <AvButton type="button" size="sm" variant="ghost" @click="openEditTransaction(transaction)" :disabled="loading">Edit</AvButton>
                        <AvButton type="button" size="sm" variant="ghost" @click="deleteTransaction(transaction.id)" :disabled="loading">Delete</AvButton>
                      </div>
                    </td>
                  </tr>
                </template>
              </tbody>
            </AvTable>
          </template>
        </AvCard>
        </div>

        <template x-if="$store.appDrawer.activeDrawer === 'createTransaction'">
          <TransactionDrawer title="Create transaction" description="Add a new income or expense entry.">
            <template x-if="quickEntryLabel">
              <p class="av-text-soft">Flow: <span x-text="quickEntryLabel"></span></p>
            </template>
            <div class="app-form-grid">
              <label class="app-field">
                <span class="app-label">Account</span>
                <select class="app-input" x-model="transactionForm.accountId">
                  <option value="">Select account</option>
                  <template x-for="account in visibleAccounts" :key="account.id">
                    <option :value="account.id" x-text="account.name"></option>
                  </template>
                </select>
              </label>
              <label class="app-field">
                <span class="app-label">Category</span>
                <select class="app-input" x-model="transactionForm.categoryId">
                  <option value="" x-text="transactionForm.type === 'transfer' ? 'No category for transfers' : 'Select category'"></option>
                  <template x-for="category in transactionSelectableCategories" :key="category.id">
                    <option :value="category.id" x-text="category.name"></option>
                  </template>
                </select>
              </label>

              <template x-if="quickEntryType && quickEntryCommonCategories.length > 0">
                <div class="app-field app-field-wide">
                  <span class="app-label">Common categories</span>
                  <div class="app-common-categories">
                    <template x-for="category in quickEntryCommonCategories" :key="`quick-cat-${category.id}`">
                      <AvButton
                        type="button"
                        variant="ghost"
                        @click="setQuickCategory(category.id)"
                      >
                        <span x-text="category.name"></span>
                      </AvButton>
                    </template>
                  </div>
                </div>
              </template>
              <label class="app-field">
                <span class="app-label">Type</span>
                <select class="app-input" :value="transactionForm.type" @change="setTransactionType($event.target.value)">
                  <option value="expense">Expense</option>
                  <option value="income">Income</option>
                  <option value="transfer">Transfer</option>
                </select>
              </label>
              <template x-if="transactionForm.type === 'transfer'">
                <label class="app-field">
                  <span class="app-label">Destination account</span>
                  <select class="app-input" x-model="transactionForm.transferAccountId">
                    <option value="">Select destination account</option>
                    <template x-for="account in visibleAccounts.filter((account) => account.id !== transactionForm.accountId)" :key="`transfer-create-${account.id}`">
                      <option :value="account.id" x-text="account.name"></option>
                    </template>
                  </select>
                </label>
              </template>
              <label class="app-field">
                <span class="app-label">Amount</span>
                <input class="app-input" type="number" step="0.01" x-model="transactionForm.amount" />
              </label>
              <label class="app-field">
                <span class="app-label">Currency code</span>
                <input class="app-input" type="text" x-model="transactionForm.currency" maxlength="10" :placeholder="effectiveCurrencyCode || 'AED'" />
              </label>
              <label class="app-field">
                <span class="app-label">Date</span>
                <input class="app-input" type="date" x-model="transactionForm.transactionDate" />
              </label>
              <label class="app-field app-field-wide">
                <span class="app-label">Description</span>
                <textarea class="app-input" x-model="transactionForm.description" rows="3" maxlength="500"></textarea>
              </label>
            </div>
            <p class="av-text-soft">V1 totals assume one currency. Leave this aligned to the app currency shown above.</p>
            <div slot="notice">
              <p class="app-form-error" x-show="error" x-text="error"></p>
            </div>
            <div slot="actions" class="av-row-wrap av-drawer-footer-actions">
              <AvButton variant="ghost" type="button" @click="$store.appDrawer.close()" :disabled="loading">Cancel</AvButton>
              <AvButton type="button" @click="submitCreateTransaction" :disabled="loading">
                <span x-show="!loading">Create transaction</span>
                <span x-show="loading">Saving...</span>
              </AvButton>
            </div>
          </TransactionDrawer>
        </template>

        <template x-if="$store.appDrawer.activeDrawer === 'createAccount'">
          <TransactionDrawer
            title="Create account"
            description="Add a new account in the standard drawer flow."
            onClose="closeAccountDrawer()"
          >
            <div class="app-form-grid">
              <label class="app-field">
                <span class="app-label">Name</span>
                <input class="app-input" type="text" x-model="accountForm.name" maxlength="120" />
              </label>
              <label class="app-field">
                <span class="app-label">Type</span>
                <input class="app-input" type="text" x-model="accountForm.type" maxlength="60" placeholder="cash / bank / card" />
              </label>
              <label class="app-field">
                <span class="app-label">Currency code</span>
                <input class="app-input" type="text" x-model="accountForm.currency" maxlength="10" placeholder="AED" />
              </label>
              <label class="app-field">
                <span class="app-label">Starting balance</span>
                <input class="app-input" type="number" step="0.01" x-model="accountForm.startingBalance" />
              </label>
            </div>
            <p class="av-text-soft">Expense Tracker V1 uses a single currency across accounts and totals. Your first saved currency becomes the app currency.</p>
            <div slot="notice">
              <p class="app-form-error" x-show="error" x-text="error"></p>
            </div>
            <div slot="actions" class="av-row-wrap av-drawer-footer-actions">
              <AvButton variant="ghost" type="button" @click="closeAccountDrawer()" :disabled="loading">Cancel</AvButton>
              <AvButton type="button" @click="createAccount" :disabled="loading">
                <span x-show="!loading">Create account</span>
                <span x-show="loading">Saving...</span>
              </AvButton>
            </div>
          </TransactionDrawer>
        </template>

        <template x-if="$store.appDrawer.activeDrawer === 'createCategory'">
          <TransactionDrawer
            title="Create category"
            description="Add a new category in the standard drawer flow."
            onClose="closeCategoryDrawer()"
          >
            <div class="app-form-grid">
              <label class="app-field">
                <span class="app-label">Name</span>
                <input class="app-input" type="text" x-model="categoryForm.name" maxlength="120" />
              </label>
              <label class="app-field">
                <span class="app-label">Kind</span>
                <select class="app-input" x-model="categoryForm.type">
                  <option value="expense">Expense</option>
                  <option value="income">Income</option>
                  <option value="transfer">Transfer</option>
                </select>
              </label>
            </div>
            <div slot="notice">
              <p class="app-form-error" x-show="error" x-text="error"></p>
            </div>
            <div slot="actions" class="av-row-wrap av-drawer-footer-actions">
              <AvButton variant="ghost" type="button" @click="closeCategoryDrawer()" :disabled="loading">Cancel</AvButton>
              <AvButton type="button" @click="createCategory" :disabled="loading">
                <span x-show="!loading">Create category</span>
                <span x-show="loading">Saving...</span>
              </AvButton>
            </div>
          </TransactionDrawer>
        </template>

        <template x-if="$store.appDrawer.activeDrawer === 'editTransaction'">
          <TransactionDrawer title="Edit transaction" description="Update an existing transaction entry.">
            <div class="app-form-grid">
              <label class="app-field">
                <span class="app-label">Account</span>
                <select class="app-input" x-model="transactionForm.accountId">
                  <option value="">Select account</option>
                  <template x-for="account in visibleAccounts" :key="account.id">
                    <option :value="account.id" x-text="account.name"></option>
                  </template>
                </select>
              </label>
              <label class="app-field">
                <span class="app-label">Category</span>
                <select class="app-input" x-model="transactionForm.categoryId">
                  <option value="" x-text="transactionForm.type === 'transfer' ? 'No category for transfers' : 'Select category'"></option>
                  <template x-for="category in transactionSelectableCategories" :key="category.id">
                    <option :value="category.id" x-text="category.name"></option>
                  </template>
                </select>
              </label>
              <label class="app-field">
                <span class="app-label">Type</span>
                <select class="app-input" :value="transactionForm.type" @change="setTransactionType($event.target.value)">
                  <option value="expense">Expense</option>
                  <option value="income">Income</option>
                  <option value="transfer">Transfer</option>
                </select>
              </label>
              <template x-if="transactionForm.type === 'transfer'">
                <label class="app-field">
                  <span class="app-label">Destination account</span>
                  <select class="app-input" x-model="transactionForm.transferAccountId">
                    <option value="">Select destination account</option>
                    <template x-for="account in visibleAccounts.filter((account) => account.id !== transactionForm.accountId)" :key="`transfer-edit-${account.id}`">
                      <option :value="account.id" x-text="account.name"></option>
                    </template>
                  </select>
                </label>
              </template>
              <label class="app-field">
                <span class="app-label">Amount</span>
                <input class="app-input" type="number" step="0.01" x-model="transactionForm.amount" />
              </label>
              <label class="app-field">
                <span class="app-label">Currency code</span>
                <input class="app-input" type="text" x-model="transactionForm.currency" maxlength="10" :placeholder="effectiveCurrencyCode || 'AED'" />
              </label>
              <label class="app-field">
                <span class="app-label">Date</span>
                <input class="app-input" type="date" x-model="transactionForm.transactionDate" />
              </label>
              <label class="app-field app-field-wide">
                <span class="app-label">Description</span>
                <textarea class="app-input" x-model="transactionForm.description" rows="3" maxlength="500"></textarea>
              </label>
            </div>
            <p class="av-text-soft">V1 totals assume one currency. Leave this aligned to the app currency shown above.</p>
            <div slot="notice">
              <p class="app-form-error" x-show="error" x-text="error"></p>
            </div>
            <div slot="actions" class="av-row-wrap av-drawer-footer-actions">
              <AvButton variant="ghost" type="button" @click="$store.appDrawer.close()" :disabled="loading">Cancel</AvButton>
              <AvButton type="button" @click="submitUpdateTransaction" :disabled="loading">
                <span x-show="!loading">Save changes</span>
                <span x-show="loading">Saving...</span>
              </AvButton>
            </div>
          </TransactionDrawer>
        </template>
      </div>
    </AvContainer>
  </section>
</AppShell>

